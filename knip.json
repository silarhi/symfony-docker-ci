{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "entry": [
        "assets/**/pages/**/*.{js,jsx}",
        "assets/**/controllers/**/*.{js,jsx}"
    ],
    "project": ["assets/**/*.{js,jsx,ts,tsx}"],
    "paths": {
        "@/*": ["assets/*"]
    },
    "ignoreBinaries": ["vendor/bin/.+"],
    "rules": {
        "unlisted": "off",
        "unresolved": "off"
    },
    "ignoreDependencies": [
        "core-js",
        "@tabler/core",
        "@hotwired/turbo",
        "^@symfony/ux-"
    ]
}
