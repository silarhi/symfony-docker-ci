{
    "license": "MIT",
    "private": true,
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "dev-server": "encore dev-server",
        "dev": "encore dev",
        "watch": "encore dev --watch",
        "build": "encore production --progress",
        "prepare": "husky",
        "lint": "biome check --write assets",
        "lint-ci": "biome check assets",
        "prettier": "prettier --write \"assets/**/*.{scss,md}\"",
        "format": "yarn lint && yarn prettier",
        "knip": "knip"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,json}": "biome check --write --no-errors-on-unmatched",
        "*.{scss,md,yaml,yml}": "prettier --write",
        "*.php": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "*.twig": "vendor/bin/twig-cs-fixer lint --fix --config=.twig-cs-fixer.php",
        "composer.json": "composer normalize"
    },
    "devDependencies": {
        "@babel/core": "^7.28.5",
        "@babel/preset-env": "^7.29.5",
        "@babel/preset-react": "^7.28.5",
        "@biomejs/biome": "^2.5.1",
        "@hotwired/stimulus": "^3.2.2",
        "@hotwired/turbo": "^8.0.21",
        "@symfony/stimulus-bridge": "^4.0.1",
        "@symfony/ux-turbo": "file:vendor/symfony/ux-turbo/assets",
        "@symfony/webpack-encore": "^6",
        "core-js": "^3.46.0",
        "husky": "^9.1.7",
        "knip": "^6.23.0",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.1",
        "prop-types": "^15.8.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "sass": "^1.101.0",
        "sass-loader": "^17.0.0",
        "webpack": "^5.108.1",
        "webpack-cli": "^7.1.0",
        "webpack-notifier": "^1.15.0"
    },
    "dependencies": {
        "@tabler/core": "^1.4.0"
    }
}
