{% extends 'base.html.twig' %}

{% block title %}PicassoBundle showcase{% endblock %}

{% block body %}
    <div class="container my-4">
        <div class="mb-5">
            <h1>PicassoBundle showcase</h1>
            <p class="lead">
                A live demo of the <a href="https://github.com/silarhi/picasso-bundle" target="_blank" rel="noopener">silarhi/picasso-bundle</a>
                Symfony package &mdash; the image component that was missing from the Symfony ecosystem.
            </p>
            <p>
                Every image below is rendered through the same Twig component: <code>&lt;twig:Picasso:Image&gt;</code>.
                The bundle takes care of generating a full <code>&lt;picture&gt;</code> element with AVIF and WebP sources,
                a JPEG fallback, responsive <code>srcset</code>, auto-detected dimensions and a blur placeholder inlined
                as a CSS <code>background-image</code>.
            </p>
            <p class="mb-0">
                The transformer used in this project is <strong>Glide</strong> running locally with the GD driver,
                and signed URLs to prevent abuse. Transformed image variants are cached under
                <code>var/picasso-cache/</code>.
            </p>
        </div>

        <h2>Responsive grid with <code>sizes</code></h2>
        <p>
            Three images laid out in a Bootstrap grid. The <code>sizes</code> attribute is forwarded to the component,
            and the <code>srcset</code> is generated automatically from the breakpoints configured in
            <code>picasso.yaml</code>.
        </p>
        <div class="row row-cols-1 row-cols-md-3 mb-5">
            {% for image in ['destiny-wiens-1332880-unsplash.jpg', 'diana-parkhouse-1166627-unsplash.jpg', 'elvira-visser-k89j1SUqf5U-unsplash.jpg'] %}
                <div class="col">
                    <div class="card mb-3 shadow-sm">
                        <twig:Picasso:Image
                            src="{{ image }}"
                            width="600"
                            height="400"
                            sizes="(max-width: 768px) 100vw, 33vw"
                            fit="cover"
                            alt="A beautiful kitten"
                            class="card-img-top"
                        />
                        <div class="card-body">
                            <h5 class="card-title">Responsive grid</h5>
                            <p class="card-text">
                                One line of Twig, and you get a <code>&lt;picture&gt;</code> element
                                with every format and every size variant.
                            </p>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <h2>Different <code>fit</code> modes</h2>
        <p>
            The same source file rendered with three different cropping strategies.
        </p>
        <div class="row row-cols-1 row-cols-md-3 mb-5">
            <div class="col mb-3 text-center">
                <div class="bg-light p-3">
                    <twig:Picasso:Image
                        src="edgar-edgar-712801-unsplash.jpg"
                        width="300"
                        height="300"
                        fit="contain"
                        alt="300x300px, contain"
                        class="img-fluid d-block mx-auto shadow-sm"
                    />
                </div>
                <span class="text-muted small">300x300px, <code>fit="contain"</code></span>
            </div>
            <div class="col mb-3 text-center">
                <div class="bg-light p-3">
                    <twig:Picasso:Image
                        src="edgar-edgar-712801-unsplash.jpg"
                        width="300"
                        height="300"
                        fit="cover"
                        alt="300x300px, cover"
                        class="img-fluid d-block mx-auto shadow-sm"
                    />
                </div>
                <span class="text-muted small">300x300px, <code>fit="cover"</code></span>
            </div>
            <div class="col mb-3 text-center">
                <div class="bg-light p-3">
                    <twig:Picasso:Image
                        src="edgar-edgar-712801-unsplash.jpg"
                        width="300"
                        height="300"
                        fit="crop"
                        alt="300x300px, crop"
                        class="img-fluid d-block mx-auto shadow-sm"
                    />
                </div>
                <span class="text-muted small">300x300px, <code>fit="crop"</code></span>
            </div>
        </div>

        <h2>Priority image (LCP)</h2>
        <p>
            With <code>:priority="true"</code>, the image is loaded with <code>loading="eager"</code> and
            <code>fetchpriority="high"</code>. The blur placeholder is automatically disabled since it would
            only slow down the first paint. This is the mode you want for a hero banner.
        </p>
        <div class="mb-5">
            <twig:Picasso:Image
                src="jacalyn-beales-669247-unsplash.jpg"
                width="1200"
                height="500"
                sizes="100vw"
                fit="cover"
                :priority="true"
                alt="Hero banner"
                class="img-fluid w-100 rounded shadow"
            />
        </div>

        <h2>Individual overrides</h2>
        <p>
            Two examples showing per-image overrides: a custom quality setting on the left, and an image
            with its blur placeholder explicitly disabled on the right.
        </p>
        <div class="row row-cols-1 row-cols-md-2 mb-5">
            <div class="col mb-3">
                <h5>Quality set to 40% (<code>:quality="40"</code>)</h5>
                <twig:Picasso:Image
                    src="diana-parkhouse-1166627-unsplash.jpg"
                    width="600"
                    height="400"
                    :quality="40"
                    fit="cover"
                    alt="Low quality"
                    class="img-fluid shadow-sm"
                />
            </div>
            <div class="col mb-3">
                <h5>No placeholder (<code>:placeholder="false"</code>)</h5>
                <twig:Picasso:Image
                    src="diana-parkhouse-1166627-unsplash.jpg"
                    width="600"
                    height="400"
                    :placeholder="false"
                    fit="cover"
                    alt="No placeholder"
                    class="img-fluid shadow-sm"
                />
            </div>
        </div>

        <div class="alert alert-info">
            <strong>See also:</strong> the legacy version of this page, which uses Glide directly
            (no PicassoBundle on top), is still available at <a href="{{ path('images') }}">/images</a>.
            Handy for comparing how much Twig code you actually need between the two approaches.
        </div>
    </div>
{% endblock %}
